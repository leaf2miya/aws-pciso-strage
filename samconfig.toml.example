version = 0.1

[default.deploy.parameters]
stack_name = "your-stack-name"
region = "ap-northeast-1"
confirm_changeset = true
resolve_s3 = true
capabilities = "CAPABILITY_IAM"
disable_rollback = true
parameter_overrides = "S3BucketName=your-s3-bucket-name DynamoDBTableName=your-dynamodb-table-name LambdaRoleArn=arn:aws:iam::123456789012:role/your-lambda-role-name"
